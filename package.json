{
  "name": "nodejs-fastapi-hello-world-app",
  "version": "1.0.0",
  "description": "A simple Node.js + FastAPI hello world app for Databricks Apps",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:frontend",
    "build:frontend": "vite build frontend --emptyOutDir",
    "dev": "vite frontend",
    "start": "uvicorn backend.main:app --port 8000",
    "start:dev": "uvicorn backend.main:app --reload --port 8000"
  },
  "dependencies": {
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/sankey": "^0.99.0",
    "@nivo/treemap": "^0.99.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
